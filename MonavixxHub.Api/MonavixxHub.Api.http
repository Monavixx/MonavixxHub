### Создать флэшкарту с картинкой
POST {{Host}}/api/flashcards
Authorization: Bearer {{token}}
Content-Type: multipart/form-data; boundary=boundary

--boundary
Content-Disposition: form-data; name="front"

Cat
--boundary
Content-Disposition: form-data; name="back"

Кошка
--boundary
Content-Disposition: form-data; name="transcription"

kæt
--boundary
Content-Disposition: form-data; name="image"; filename="cat.jpg"
Content-Type: image/jpeg

< ./cat.jpg
--boundary--


